---
// Hero component
---

<section class="bg-navy-900 text-white py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-3 font-serif">
        Department of Bioengineering
      </h1>
      <p class="text-lg md:text-xl mb-2 text-navy-100">
        Christian Medical College, Vellore
      </p>
      <p class="text-base md:text-lg mb-4 text-navy-100">
        Leading Innovation in Biomedical Engineering
      </p>
      <p class="text-sm md:text-base mb-6 max-w-3xl mx-auto text-gray-300">
        We are dedicated to advancing biomedical engineering through cutting-edge research, innovative education,
        and transformative healthcare solutions that improve lives and shape the future of medicine.
      </p>

      <!-- Call to Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-6">
        <a href="/research" class="inline-flex items-center px-6 py-2 bg-white text-navy-800 font-semibold rounded hover:bg-navy-50 transition-colors duration-200 shadow">
          Explore Our Research
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href="/team" class="inline-flex items-center px-6 py-2 border border-white text-white font-semibold rounded hover:bg-white/10 transition-colors duration-200">
          Meet Our Team
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </a>
      </div>

      <!-- Stat row -->
      <div class="flex flex-col md:flex-row justify-center items-center gap-0 border-t border-navy-700 pt-4">
        <div class="px-6 py-2 text-center md:border-r border-navy-700">
          <div class="text-xl font-bold font-serif">Medical Devices</div>
          <p class="text-gray-400 text-xs mt-0.5">Innovative biomedical instrumentation</p>
        </div>
        <div class="px-6 py-2 text-center md:border-r border-navy-700">
          <div class="text-xl font-bold font-serif">Rehabilitation Tech</div>
          <p class="text-gray-400 text-xs mt-0.5">Advanced assistive technologies</p>
        </div>
        <div class="px-6 py-2 text-center">
          <div class="text-xl font-bold font-serif">Education &amp; Research</div>
          <p class="text-gray-400 text-xs mt-0.5">Comprehensive academic programs</p>
        </div>
      </div>
    </div>
  </div>
</section>
