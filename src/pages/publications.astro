---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const journalPublications = [
  {
    title: "GMAC – A simple measure to quantify upper limb use from wrist-worn accelerometers",
    authors: "Sivakumar Balasubramanian",
    journal: "IEEE TNSRE",
    year: "2024",
    type: "Journal",
    link: "https://ieeexplore.ieee.org/document/10569004",
    doi: "10.1109/TNSRE.2024.3417964"
  },
  {
    title: "Romiumeter: An Open-Source Inertial Measurement Unit-Based Goniometer",
    authors: "Diwakar Basinepalli Reddy, Abhishek, Amal Andrews, Lenny Vasanthan, Sivakumar Balasubramanian",
    journal: "bioRxiv Preprint",
    year: "2024",
    type: "Preprint",
    link: "https://www.biorxiv.org/content/10.1101/2024.05.29.596353v1",
    doi: "10.1101/2024.05.29.596353"
  },
  {
    title: "A systematic investigation of detectors for low signal-to-noise ratio EMG signals",
    authors: "Monisha Yuvaraj, Priyanka Raja, Ann David, Etienne Burdet, Varadhan SKM, Balasubramanian S",
    journal: "F1000Research",
    year: "2023",
    type: "Journal",
    link: "https://f1000research.com/articles/12-429",
    doi: "10.12688/f1000research.131063.1"
  },
  {
    title: "The Facilitators and Barriers to Home-based Robotic Rehabilitation in India",
    authors: "Nehrujee A, Prabhakar A, Balaraman S, Bombatkar R, Prakash H, SamuelKamaleshKumar S, Aaron S, Bhattacharya S, Srinivasan S, Balasubramanian S",
    journal: "Frontiers in Stroke",
    year: "2023",
    type: "Journal",
    link: "https://www.frontiersin.org/articles/10.3389/fstro.2023.1265702/abstract",
    doi: "10.3389/fstro.2023.1265702"
  },
  {
    title: "Design and Characterization of a Self-Aligning End-Effector Robot",
    authors: "Sivakumar Balasubramanian, et al.",
    journal: "Robotics",
    year: "2023",
    type: "Journal",
    link: "",
    doi: ""
  },
  {
    title: "Comparing algorithms for assessing upper limb use",
    authors: "Sivakumar Balasubramanian, et al.",
    journal: "Frontiers in Physiology",
    year: "2022",
    type: "Journal",
    link: "",
    doi: ""
  },
  {
    title: "Encoder-Controlled Functional Electrical Stimulator",
    authors: "Sivakumar Balasubramanian, et al.",
    journal: "Bioengineering",
    year: "2022",
    type: "Journal",
    link: "",
    doi: ""
  },
  {
    title: "Plug-and-Train Robot (PLUTO) for Hand Rehabilitation",
    authors: "A Nehrujee, et al.",
    journal: "IEEE Access",
    year: "2021",
    type: "Journal",
    link: "",
    doi: ""
  },
  {
    title: "A Framework for Sensor-Based Assessment of Upper-Limb Functioning",
    authors: "Sivakumar Balasubramanian, et al.",
    journal: "Frontiers in Human Neuroscience",
    year: "2021",
    type: "Journal",
    link: "",
    doi: ""
  }
];

const conferencePublications = [
  {
    title: "A Plug-and-Train Robotic Kit (PLUTO) For Hand Rehabilitation",
    authors: "A Nehrujee, et al.",
    journal: "BioRob",
    year: "2020",
    type: "Conference",
    link: "https://ieeexplore.ieee.org/abstract/document/9224369",
    doi: "10.1109/BioRob49111.2020.9224369"
  },
  {
    title: "A Smartphone-based gaming system for vestibular rehabilitation",
    authors: "Sivakumar Balasubramanian, et al.",
    journal: "Conference",
    year: "2019",
    type: "Conference",
    link: "",
    doi: ""
  }
];
---

<Layout title="Publications - BioRehab Group">
  <div class="min-h-screen bg-white">
    <Header />
    
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-navy-800 mb-4 font-serif">
            Publications
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Our research contributions to the field of neurorehabilitation, 
            rehabilitation robotics, and bioengineering
          </p>
        </div>


        <!-- Journal Publications -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-navy-800 mb-8 font-serif">Journal Publications</h2>
          <div class="grid grid-cols-1 gap-6">
            {journalPublications.map((publication) => (
              <div class="bg-white p-6 border border-gray-200 border-l-4 border-l-navy-600">
                <div class="flex justify-between items-start mb-3">
                  <span class="px-3 py-1 text-sm font-medium bg-navy-100 text-navy-800">
                    {publication.type}
                  </span>
                  <span class="text-sm font-medium text-gray-500">{publication.year}</span>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2 leading-tight">
                  {publication.title}
                </h3>
                <p class="text-gray-600 font-medium mb-2">{publication.journal}</p>
                {publication.authors && (
                  <p class="text-sm text-gray-500 mb-3">
                    <span class="font-medium">Authors:</span> {publication.authors}
                  </p>
                )}
                <div class="flex gap-2 flex-wrap">
                  {publication.link && (
                    <a
                      href={publication.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center px-3 py-1 bg-navy-800 text-white text-sm rounded hover:bg-navy-900 transition-colors"
                    >
                      Read Paper
                    </a>
                  )}
                  {publication.doi && (
                    <a
                      href={`https://doi.org/${publication.doi}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center px-3 py-1 border border-navy-600 text-navy-600 text-sm rounded hover:bg-navy-50 transition-colors"
                    >
                      DOI
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Conference Publications -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-navy-800 mb-8 font-serif">Conference Publications</h2>
          <div class="grid grid-cols-1 gap-6">
            {conferencePublications.map((publication) => (
              <div class="bg-white p-6 border border-gray-200 border-l-4 border-l-navy-600">
                <div class="flex justify-between items-start mb-3">
                  <span class="px-3 py-1 text-sm font-medium bg-navy-100 text-navy-800">
                    {publication.type}
                  </span>
                  <span class="text-sm font-medium text-gray-500">{publication.year}</span>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2 leading-tight">
                  {publication.title}
                </h3>
                <p class="text-gray-600 font-medium mb-2">{publication.journal}</p>
                {publication.authors && (
                  <p class="text-sm text-gray-500 mb-3">
                    <span class="font-medium">Authors:</span> {publication.authors}
                  </p>
                )}
                <div class="flex gap-2 flex-wrap">
                  {publication.link && (
                    <a
                      href={publication.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center px-3 py-1 bg-navy-800 text-white text-sm rounded hover:bg-navy-900 transition-colors"
                    >
                      Read Paper
                    </a>
                  )}
                  {publication.doi && (
                    <a
                      href={`https://doi.org/${publication.doi}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center px-3 py-1 border border-navy-600 text-navy-600 text-sm rounded hover:bg-navy-50 transition-colors"
                    >
                      DOI
                    </a>
                  )}
                </div>
              </div>
            ))}}
          </div>
        </div>

        <!-- Research Focus Areas -->
        <div class="bg-navy-50 p-8 rounded">
          <h2 class="text-2xl font-semibold text-navy-800 mb-6 text-center font-serif">
            Research Focus Areas
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="bg-white p-4 rounded-lg text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Rehabilitation Technologies</h3>
              <p class="text-sm text-gray-600">Robotic systems and sensor-based tools</p>
            </div>
            <div class="bg-white p-4 rounded-lg text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Movement Analysis</h3>
              <p class="text-sm text-gray-600">Quantitative assessment methods</p>
            </div>
            <div class="bg-white p-4 rounded-lg text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Signal Processing</h3>
              <p class="text-sm text-gray-600">EMG and sensor data analysis</p>
            </div>
            <div class="bg-white p-4 rounded-lg text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Bioengineering</h3>
              <p class="text-sm text-gray-600">Medical device development</p>
            </div>
            <div class="bg-white p-4 rounded-lg text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Neurorehabilitation</h3>
              <p class="text-sm text-gray-600">Clinical applications and therapy</p>
            </div>
            <div class="bg-white p-4 rounded-lg text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Open Science</h3>
              <p class="text-sm text-gray-600">Open-source tools and frameworks</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>