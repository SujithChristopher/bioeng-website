---

<Layout title="Publications - Department of Bioengineering, CMC Vellore">
  <div class="min-h-screen bg-white">
    <Header />

    <!-- Page Header -->
    <section class="py-12 bg-navy-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 font-serif">Publications</h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Research contributions from the Department of Bioengineering, CMC Vellore
        </p>
      </div>
    </section>

    <section class="py-12 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Section jump links -->
        <div class="flex gap-4 mb-10 text-sm border-b border-gray-200 pb-4">
          <a href="#journals" class="text-navy-600 hover:underline">Journal Publications ({journalPublications.length})</a>
          <span class="text-gray-300">·</span>
          <a href="#preprints" class="text-navy-600 hover:underline">Preprints ({preprintPublications.length})</a>
          <span class="text-gray-300">·</span>
          <a href="#conferences" class="text-navy-600 hover:underline">Conference ({conferencePublications.length})</a>
        </div>

        <!-- Journal Publications -->
        <div class="mb-8" id="journals">
          <details open>
            <summary class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4 cursor-pointer list-none flex justify-between items-center">
              Journal Publications
              <span class="text-sm font-normal text-gray-400">{journalPublications.length} papers</span>
            </summary>
            <div class="divide-y divide-gray-100">
              {journalPublications.map((pub) => (
                <div class="py-3 flex gap-4 items-baseline">
                  <span class="text-xs text-gray-400 font-mono shrink-0 w-8">{pub.year}</span>
                  <div class="min-w-0">
                    {pub.link
                      ? <a href={pub.link} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-navy-800 hover:underline leading-snug">{pub.title}</a>
                      : <span class="text-sm font-medium text-navy-800 leading-snug">{pub.title}</span>
                    }
                    <p class="text-xs text-gray-500 mt-0.5 leading-snug">{pub.authors}</p>
                    <p class="text-xs text-gray-600 mt-0.5">
                      <span class="italic">{pub.journal}</span>
                      {pub.doi && (
                        <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noopener noreferrer" class="ml-2 text-navy-600 hover:underline not-italic">DOI</a>
                      )}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </details>
        </div>

        <!-- Preprints -->
        <div class="mb-8" id="preprints">
          <details open>
            <summary class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4 cursor-pointer list-none flex justify-between items-center">
              Preprints
              <span class="text-sm font-normal text-gray-400">{preprintPublications.length} papers</span>
            </summary>
            <div class="divide-y divide-gray-100">
              {preprintPublications.map((pub) => (
                <div class="py-3 flex gap-4 items-baseline">
                  <span class="text-xs text-gray-400 font-mono shrink-0 w-8">{pub.year}</span>
                  <div class="min-w-0">
                    {pub.link
                      ? <a href={pub.link} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-navy-800 hover:underline leading-snug">{pub.title}</a>
                      : <span class="text-sm font-medium text-navy-800 leading-snug">{pub.title}</span>
                    }
                    <p class="text-xs text-gray-500 mt-0.5 leading-snug">{pub.authors}</p>
                    <p class="text-xs text-gray-600 mt-0.5">
                      <span class="italic">{pub.journal}</span>
                      {pub.doi && (
                        <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noopener noreferrer" class="ml-2 text-navy-600 hover:underline not-italic">DOI</a>
                      )}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </details>
        </div>

        <!-- Conference Publications -->
        <div class="mb-8" id="conferences">
          <details open>
            <summary class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4 cursor-pointer list-none flex justify-between items-center">
              Conference Publications
              <span class="text-sm font-normal text-gray-400">{conferencePublications.length} papers</span>
            </summary>
            <div class="divide-y divide-gray-100">
              {conferencePublications.map((pub) => (
                <div class="py-3 flex gap-4 items-baseline">
                  <span class="text-xs text-gray-400 font-mono shrink-0 w-8">{pub.year}</span>
                  <div class="min-w-0">
                    {pub.link
                      ? <a href={pub.link} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-navy-800 hover:underline leading-snug">{pub.title}</a>
                      : <span class="text-sm font-medium text-navy-800 leading-snug">{pub.title}</span>
                    }
                    <p class="text-xs text-gray-500 mt-0.5 leading-snug">{pub.authors}</p>
                    <p class="text-xs text-gray-600 mt-0.5">
                      <span class="italic">{pub.journal}</span>
                      {pub.doi && (
                        <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noopener noreferrer" class="ml-2 text-navy-600 hover:underline not-italic">DOI</a>
                      )}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </details>
        </div>

      </div>
    </section>

    <Footer />
  </div>
</Layout>
