---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Join Us - BioRehab Group">
  <div class="min-h-screen bg-white">
    <Header />
    
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-navy-800 mb-4 font-serif">
            Join Us
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Be part of our mission to advance neurorehabilitation through 
            innovative research and technology development
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
          <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-8 text-center">
            <div class="bg-navy-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-6">
              <svg class="w-10 h-10 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-semibold text-navy-800 mb-4 font-serif">MS/PhD Students</h2>
            <p class="text-gray-600 mb-6">
              Join our research program and work on cutting-edge projects in 
              neurorehabilitation, robotics, and bioengineering.
            </p>
            <ul class="text-left space-y-2 text-gray-700">
              <li>• Research assistantships available</li>
              <li>• Access to state-of-the-art facilities</li>
              <li>• Mentorship from experienced faculty</li>
              <li>• Collaboration opportunities</li>
              <li>• Publication and conference opportunities</li>
            </ul>
          </div>

          <div class="bg-navy-50 p-8 text-center">
            <div class="bg-navy-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-6">
              <svg class="w-10 h-10 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H8m8 0v5a2 2 0 01-2 2H10a2 2 0 01-2-2V6m8 0V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H8m8 0v5a2 2 0 01-2 2H10a2 2 0 01-2-2V6"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-semibold text-navy-800 mb-4 font-serif">Internships</h2>
            <p class="text-gray-600 mb-6">
              Gain hands-on experience in rehabilitation research and technology 
              development through our internship programs.
            </p>
            <ul class="text-left space-y-2 text-gray-700">
              <li>• Summer research internships</li>
              <li>• Project-based learning</li>
              <li>• Skill development workshops</li>
              <li>• Networking opportunities</li>
              <li>• Certificate of completion</li>
            </ul>
          </div>

          <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-8 text-center">
            <div class="bg-navy-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-6">
              <svg class="w-10 h-10 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-semibold text-navy-800 mb-4 font-serif">Project Staff</h2>
            <p class="text-gray-600 mb-6">
              Full-time research positions for experienced professionals in 
              engineering, research, and technology development.
            </p>
            <ul class="text-left space-y-2 text-gray-700">
              <li>• Competitive compensation</li>
              <li>• Professional development</li>
              <li>• Research project leadership</li>
              <li>• Industry collaboration</li>
              <li>• Career advancement opportunities</li>
            </ul>
          </div>
        </div>

        <div class="bg-navy-50 p-8 mb-16">
          <h2 class="text-2xl font-semibold text-navy-800 mb-6 text-center font-serif">
            What We're Looking For
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Engineering Background</h3>
              <p class="text-sm text-gray-600">Biomedical, Mechanical, Electrical, or Computer Engineering</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Programming Skills</h3>
              <p class="text-sm text-gray-600">Python, MATLAB, C++, or similar languages</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Research Interest</h3>
              <p class="text-sm text-gray-600">Rehabilitation, robotics, or biomedical engineering</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Collaborative Spirit</h3>
              <p class="text-sm text-gray-600">Team-oriented and interdisciplinary mindset</p>
            </div>
          </div>
        </div>

        <div class="bg-navy-900 text-white p-8 rounded text-center mb-16">
          <h2 class="text-2xl font-semibold mb-8 font-serif">Why Join BioRehab Group?</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div>
              <h3 class="font-semibold mb-2 font-serif">Cutting-edge Research</h3>
              <p class="text-gray-400">Work on innovative rehabilitation technologies</p>
            </div>
            <div>
              <h3 class="font-semibold mb-2 font-serif">Collaborative Environment</h3>
              <p class="text-gray-400">Interdisciplinary team and international collaborations</p>
            </div>
            <div>
              <h3 class="font-semibold mb-2 font-serif">Innovation Focus</h3>
              <p class="text-gray-400">Translate research into real-world applications</p>
            </div>
            <div>
              <h3 class="font-semibold mb-2 font-serif">Career Growth</h3>
              <p class="text-gray-400">Professional development and mentorship</p>
            </div>
            <div>
              <h3 class="font-semibold mb-2 font-serif">Impact</h3>
              <p class="text-gray-400">Make a difference in patients' lives</p>
            </div>
            <div>
              <h3 class="font-semibold mb-2 font-serif">Global Recognition</h3>
              <p class="text-gray-400">Publication and conference opportunities</p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-200 p-8 text-center">
          <h2 class="text-2xl font-semibold text-navy-800 mb-4 font-serif">Ready to Apply?</h2>
          <p class="text-gray-600 mb-6">
            Send us your CV and a cover letter explaining your interest in our research.
          </p>
          <div class="space-y-4">
            <div>
              <h3 class="font-semibold text-gray-800">Contact Information</h3>
              <p class="text-gray-600">Department of Bioengineering</p>
              <p class="text-gray-600">Christian Medical College Vellore</p>
              <p class="text-gray-600">Tamil Nadu, India</p>
            </div>
            <div>
              <p class="text-gray-600">
                For inquiries: <a href="mailto:siva82kb@cmcvellore.ac.in" class="text-navy-600 hover:text-navy-800">siva82kb@cmcvellore.ac.in</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>