---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Collaborations - BioRehab Group">
  <div class="min-h-screen bg-white">
    <Header />
    
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Collaborations
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Building partnerships to advance neurorehabilitation research and technology
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
          <div class="bg-blue-50 p-8 rounded-lg">
            <h2 class="text-2xl font-semibold text-gray-900 mb-6">
              Academic Collaborations
            </h2>
            <div class="space-y-4">
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">Dr. Sujatha Srinivasan</h3>
                <p class="text-gray-600 mb-1">IIT Madras</p>
                <p class="text-sm text-gray-500">Collaborative research in rehabilitation robotics and movement analysis</p>
              </div>
            </div>
          </div>

          <div class="bg-green-50 p-8 rounded-lg">
            <h2 class="text-2xl font-semibold text-gray-900 mb-6">
              Funding Partners
            </h2>
            <div class="space-y-4">
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">Department of Biotechnology</h3>
                <p class="text-gray-600 mb-1">Government of India</p>
                <p class="text-sm text-gray-500">Supporting neurorehabilitation research initiatives</p>
              </div>
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">NHHID</h3>
                <p class="text-gray-600 mb-1">Department of Science and Technology</p>
                <p class="text-sm text-gray-500">Technology development and innovation support</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 p-8 rounded-lg mb-16">
          <h2 class="text-2xl font-semibold text-gray-900 mb-6 text-center">
            Research Areas of Collaboration
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-lg text-center">
              <div class="bg-blue-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 7.172V5L8 4z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Robotics Research</h3>
              <p class="text-sm text-gray-600">Collaborative development of rehabilitation robots</p>
            </div>
            
            <div class="bg-white p-6 rounded-lg text-center">
              <div class="bg-green-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Clinical Studies</h3>
              <p class="text-sm text-gray-600">Joint clinical trials and outcome assessments</p>
            </div>
            
            <div class="bg-white p-6 rounded-lg text-center">
              <div class="bg-purple-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Technology Transfer</h3>
              <p class="text-sm text-gray-600">Translating research into practical applications</p>
            </div>
          </div>
        </div>

        <div class="bg-blue-600 text-white p-8 rounded-lg text-center">
          <h2 class="text-2xl font-semibold mb-4">Partner With Us</h2>
          <p class="text-lg mb-6">
            Interested in collaborating on neurorehabilitation research?
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
              <h3 class="font-semibold mb-2">Research Institutions</h3>
              <p class="text-blue-100">Joint research projects and publications</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2">Industry Partners</h3>
              <p class="text-blue-100">Technology development and commercialization</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2">Clinical Partners</h3>
              <p class="text-blue-100">Clinical validation and implementation</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>