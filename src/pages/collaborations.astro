---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Collaborations - BioRehab Group">
  <div class="min-h-screen bg-white">
    <Header />
    
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-navy-800 mb-4 font-serif">
            Collaborations
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Building partnerships to advance neurorehabilitation research and technology
          </p>
        </div>

        <!-- Inter-CMC Collaborations -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-navy-800 mb-8 text-center font-serif">Inter-CMC, Vellore Collaborations</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-gray-800 mb-2">Dept of Neurological Sciences</h3>
              <p class="text-gray-600">CMC Vellore</p>
            </div>
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-gray-800 mb-2">Dept. of Physical Medicine and Rehabilitation</h3>
              <p class="text-gray-600">CMC Vellore</p>
            </div>
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-gray-800 mb-2">Dept of Physiology</h3>
              <p class="text-gray-600">CMC Vellore</p>
            </div>
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-gray-800 mb-2">Dept. of ENT</h3>
              <p class="text-gray-600">CMC Vellore</p>
            </div>
          </div>
        </div>

        <!-- National Collaborations -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-navy-800 mb-8 text-center font-serif">National Collaborations</h2>
          
          <!-- IIT Madras -->
          <div class="mb-8">
            <h3 class="text-xl font-semibold text-navy-800 mb-4 font-serif">IIT Madras Researchers</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
                <h4 class="font-semibold text-gray-800 mb-2">Dr. Sujatha Srinivasan</h4>
                <p class="text-gray-600 mb-1">R2D2 lab</p>
                <p class="text-sm text-gray-500">IIT Madras</p>
              </div>
              <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
                <h4 class="font-semibold text-gray-800 mb-2">Dr. Varadhan SKM</h4>
                <p class="text-gray-600 mb-1">Neuromechanics lab</p>
                <p class="text-sm text-gray-500">IIT Madras</p>
              </div>
              <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
                <h4 class="font-semibold text-gray-800 mb-2">Dr. Manish Anand</h4>
                <p class="text-gray-600 mb-1">Bionex lab</p>
                <p class="text-sm text-gray-500">IIT Madras</p>
              </div>
            </div>
          </div>

          <!-- Other National Collaborators -->
          <div class="mb-8">
            <h3 class="text-xl font-semibold text-navy-800 mb-4 font-serif">Other National Collaborators</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
                <h4 class="font-semibold text-gray-800 mb-2">Dr. Jeyaraj Pandiyan, Dr. Dorcas Gandhi</h4>
                <p class="text-gray-600">CMC Ludhiana</p>
              </div>
              <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
                <h4 class="font-semibold text-gray-800 mb-2">Dr. John Solomon</h4>
                <p class="text-gray-600">Department of Physiotherapy</p>
              </div>
              <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
                <h4 class="font-semibold text-gray-800 mb-2">Dr. Ajith, Dr. Anna</h4>
                <p class="text-gray-600">Adivasi Hospital Gudalur</p>
              </div>
            </div>
          </div>
        </div>

        <!-- International Collaborations -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-navy-800 mb-8 text-center font-serif">International Collaborations</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- United Kingdom -->
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-navy-800 mb-3 font-serif">United Kingdom</h3>
              <div class="space-y-3">
                <div>
                  <h4 class="font-medium text-gray-700">Prof. Etienne Burdet</h4>
                  <p class="text-sm text-gray-600">Human Robotics group</p>
                  <p class="text-sm text-gray-500">Imperial College, London</p>
                </div>
              </div>
            </div>

            <!-- Australia -->
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-navy-800 mb-3 font-serif">Australia</h3>
              <div class="space-y-3">
                <div>
                  <h4 class="font-medium text-gray-700">Dr. Alejandro Melendez</h4>
                  <p class="text-sm text-gray-500">University of Queensland</p>
                </div>
                <div>
                  <h4 class="font-medium text-gray-700">Dr. Camila Shirota</h4>
                  <p class="text-sm text-gray-500">Griffith University</p>
                </div>
                <div>
                  <h4 class="font-medium text-gray-700">Prof. Paul Hodges</h4>
                  <p class="text-sm text-gray-500">University of Queensland</p>
                </div>
              </div>
            </div>

            <!-- Germany -->
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-navy-800 mb-3 font-serif">Germany</h3>
              <div class="space-y-3">
                <div>
                  <h4 class="font-medium text-gray-700">Dr. Ander Ramos Murguialday</h4>
                  <p class="text-sm text-gray-600">Ramos Lab</p>
                  <p class="text-sm text-gray-500">University of Tubingen</p>
                </div>
              </div>
            </div>

            <!-- Sweden -->
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-6">
              <h3 class="font-semibold text-navy-800 mb-3 font-serif">Sweden</h3>
              <div class="space-y-3">
                <div>
                  <h4 class="font-medium text-gray-700">Prof. Christian Antfolk</h4>
                  <p class="text-sm text-gray-500">Lund University</p>
                </div>
                <div>
                  <h4 class="font-medium text-gray-700">Dr. Nebojsa Malesevic</h4>
                  <p class="text-sm text-gray-500">Lund University</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Funding Sources -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-navy-800 mb-8 text-center font-serif">Funding Sources</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-8 text-center">
              <h3 class="font-semibold text-gray-800 mb-2">Department of Biotechnology</h3>
              <p class="text-gray-600">Government of India</p>
            </div>
            <div class="bg-white border border-gray-200 border-t-4 border-t-navy-700 p-8 text-center">
              <h3 class="font-semibold text-gray-800 mb-2">NHHID</h3>
              <p class="text-gray-600">Department of Science and Technology, Government of India</p>
            </div>
          </div>
        </div>

        <div class="bg-navy-50 p-8 mb-16">
          <h2 class="text-2xl font-semibold text-navy-800 mb-6 text-center font-serif">
            Research Areas of Collaboration
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-white border border-gray-200 p-6 text-center">
              <div class="bg-navy-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 7.172V5L8 4z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Robotics Research</h3>
              <p class="text-sm text-gray-600">Collaborative development of rehabilitation robots</p>
            </div>
            
            <div class="bg-white border border-gray-200 p-6 text-center">
              <div class="bg-navy-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-navy-800 mb-2">Clinical Studies</h3>
              <p class="text-sm text-gray-600">Joint clinical trials and outcome assessments</p>
            </div>

            <div class="bg-white border border-gray-200 p-6 text-center">
              <div class="bg-navy-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-navy-800 mb-2">Technology Transfer</h3>
              <p class="text-sm text-gray-600">Translating research into practical applications</p>
            </div>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="bg-navy-900 text-white p-8 rounded text-center">
          <h2 class="text-2xl font-semibold mb-4 font-serif">Partner With Us</h2>
          <p class="text-lg mb-6 text-gray-300">
            Interested in collaborating on neurorehabilitation research?
          </p>

          <div class="bg-navy-800 rounded p-6 mb-6">
            <h3 class="font-semibold mb-4 font-serif">Contact Information</h3>
            <div class="text-left max-w-md mx-auto text-gray-300">
              <p class="mb-2"><strong class="text-white">Department of Bioengineering</strong></p>
              <p class="mb-2">Christian Medical College</p>
              <p class="mb-2">Bagayam, Vellore 632002</p>
              <p class="mb-2">Tamil Nadu, India</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
              <h3 class="font-semibold mb-2 font-serif">Research Institutions</h3>
              <p class="text-gray-400">Joint research projects and publications</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2 font-serif">Industry Partners</h3>
              <p class="text-gray-400">Technology development and commercialization</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2 font-serif">Clinical Partners</h3>
              <p class="text-gray-400">Clinical validation and implementation</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>