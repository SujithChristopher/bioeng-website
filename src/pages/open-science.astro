---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Open Science - BioRehab Group">
  <div class="min-h-screen bg-white">
    <Header />
    
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Open Science
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Committed to open science principles, sharing knowledge and tools 
            to advance neurorehabilitation research globally
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
          <div class="bg-blue-50 p-8 rounded-lg">
            <h2 class="text-2xl font-semibold text-gray-900 mb-6">
              🔓 Open Source Projects
            </h2>
            <div class="space-y-4">
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">PLUTO Robot</h3>
                <p class="text-gray-600 mb-2">Plug-and-Train Robot for Hand Rehabilitation</p>
                <p class="text-sm text-gray-500">Open-source robotic platform for hand therapy</p>
              </div>
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">Romiumeter</h3>
                <p class="text-gray-600 mb-2">Open-Source IMU-Based Goniometer</p>
                <p class="text-sm text-gray-500">Tools for movement measurement and analysis</p>
              </div>
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">Assessment Frameworks</h3>
                <p class="text-gray-600 mb-2">Sensor-Based Upper-Limb Assessment</p>
                <p class="text-sm text-gray-500">Open frameworks for functional assessment</p>
              </div>
            </div>
          </div>

          <div class="bg-green-50 p-8 rounded-lg">
            <h2 class="text-2xl font-semibold text-gray-900 mb-6">
              📊 Open Data & Publications
            </h2>
            <div class="space-y-4">
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">Research Data</h3>
                <p class="text-gray-600 mb-2">Openly available datasets from our studies</p>
                <p class="text-sm text-gray-500">Supporting reproducible research</p>
              </div>
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">Publications</h3>
                <p class="text-gray-600 mb-2">Open access research papers</p>
                <p class="text-sm text-gray-500">Free access to scientific knowledge</p>
              </div>
              <div class="bg-white p-4 rounded-lg">
                <h3 class="font-semibold text-gray-800 mb-2">Protocols</h3>
                <p class="text-gray-600 mb-2">Detailed experimental protocols</p>
                <p class="text-sm text-gray-500">Enabling study replication</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 p-8 rounded-lg mb-16">
          <h2 class="text-2xl font-semibold text-gray-900 mb-6 text-center">
            Open Science Principles
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="text-center">
              <div class="bg-blue-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Open Access</h3>
              <p class="text-sm text-gray-600">Free access to research publications</p>
            </div>
            
            <div class="text-center">
              <div class="bg-green-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Open Data</h3>
              <p class="text-sm text-gray-600">Sharing research datasets</p>
            </div>
            
            <div class="text-center">
              <div class="bg-purple-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Open Source</h3>
              <p class="text-sm text-gray-600">Free and open software tools</p>
            </div>
            
            <div class="text-center">
              <div class="bg-orange-100 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Open Collaboration</h3>
              <p class="text-sm text-gray-600">Collaborative research approach</p>
            </div>
          </div>
        </div>

        <div class="bg-blue-600 text-white p-8 rounded-lg text-center">
          <h2 class="text-2xl font-semibold mb-4">Join the Open Science Movement</h2>
          <p class="text-lg mb-6">
            Contribute to advancing neurorehabilitation through open science
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
              <h3 class="font-semibold mb-2">Researchers</h3>
              <p class="text-blue-100">Use our open tools and contribute back</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2">Developers</h3>
              <p class="text-blue-100">Contribute to our open source projects</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2">Clinicians</h3>
              <p class="text-blue-100">Provide feedback and validation</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>