---

<Layout title="Team - BioRehab Group">
  <div class="min-h-screen bg-white">
    <Header />
    
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Our Team
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Meet the dedicated researchers, engineers, and students working together 
            to advance neurorehabilitation technology
          </p>
        </div>

        <!-- Faculty -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Faculty</h2>
          <div class="flex justify-center">
            <div class="max-w-sm">
              {faculty.map((member) => (
                <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                  <div class="aspect-square relative bg-gray-100 flex items-center justify-center h-48 w-48 mx-auto">
                    <img
                      src={member.image}
                      alt={member.name}
                      class="object-contain p-2 w-full h-full"
                    />
                  </div>
                  <div class="p-4">
                    <h3 class="font-semibold text-gray-900 mb-1 text-lg">{member.name}</h3>
                    {member.title && <p class="text-blue-600 font-medium mb-2 text-base">{member.title}</p>}
                    {member.education && (
                      <div class="mb-3">
                        <p class="text-sm font-medium text-gray-800 mb-1">Education:</p>
                        <ul class="text-sm text-gray-600 space-y-1">
                          {member.education.map((edu) => (
                            <li>• {edu}</li>
                          ))}
                        </ul>
                      </div>
                    )}
                    <div class="space-y-1">
                      {member.email && (
                        <a 
                          href={`mailto:${member.email}`}
                          class="text-sm text-blue-600 hover:text-blue-800 block break-all"
                        >
                          📧 {member.email}
                        </a>
                      )}
                      {member.url && (
                        <a 
                          href={member.url.startsWith('http') ? member.url : `https://${member.url}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-sm text-blue-600 hover:text-blue-800 block break-all"
                        >
                          🔗 {member.url}
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Post-Docs -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Post-Docs</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            {postdocs.map((member) => (
              <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                <div class="aspect-square relative bg-gray-100 flex items-center justify-center h-48 w-48 mx-auto">
                  <img
                    src={member.image}
                    alt={member.name}
                    class="object-contain p-2 w-full h-full"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-semibold text-gray-900 mb-1 text-lg">{member.name}</h3>
                  {member.title && <p class="text-blue-600 font-medium mb-2 text-base">{member.title}</p>}
                  {member.coGuide && <p class="text-sm text-gray-600 mb-2"><span class="font-medium">Co-guide:</span> {member.coGuide}</p>}
                  {member.education && (
                    <div class="mb-3">
                      <p class="text-sm font-medium text-gray-800 mb-1">Education:</p>
                      <ul class="text-sm text-gray-600 space-y-1">
                        {member.education.map((edu) => (
                          <li>• {edu}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  <div class="space-y-1">
                    {member.email && (
                      <a 
                        href={`mailto:${member.email}`}
                        class="text-sm text-blue-600 hover:text-blue-800 block break-all"
                      >
                        📧 {member.email}
                      </a>
                    )}
                    {member.url && (
                      <a 
                        href={member.url.startsWith('http') ? member.url : `https://${member.url}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm text-blue-600 hover:text-blue-800 block break-all"
                      >
                        🔗 {member.url}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- PhD Students -->
        <div class="mb-16">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">PhD Students</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {phdStudents.map((member) => (
              <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
