---

<Layout title="Team - BioRehab Group">
  <div class="min-h-screen bg-white">
    <Header />

    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-navy-800 mb-4 font-serif">
            Our Team
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Meet the dedicated researchers, engineers, and students working together
            to advance neurorehabilitation technology
          </p>
        </div>

        <!-- Faculty -->
        <div class="mb-16">
          <h2 class="text-2xl font-serif text-navy-800 border-b border-gray-200 pb-2 mb-6 text-center">Faculty</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            {faculty.map((member) => (
                <div class="bg-white border border-gray-200 rounded-sm overflow-hidden">
                  <div class="aspect-square relative bg-gray-100 flex items-center justify-center h-48 w-48 mx-auto">
                    <img
                      src={member.image}
                      alt={member.name}
                      class="object-contain p-2 w-full h-full"
                    />
                  </div>
                  <div class="p-4">
                    <h3 class="font-semibold text-navy-800 mb-1 text-lg font-serif">{member.name}</h3>
                    {member.title && <p class="text-navy-600 font-medium mb-2 text-base">{member.title}</p>}
                    {member.education && member.education.length > 0 && (
                      <div class="mb-3">
                        <p class="text-sm font-medium text-gray-800 mb-1">Education:</p>
                        <ul class="text-sm text-gray-600 space-y-1">
                          {member.education.map((edu) => (
                            <li>• {edu}</li>
                          ))}
                        </ul>
                      </div>
                    )}
                    <div class="space-y-1">
                      {member.email && (
                        <a
                          href={`mailto:${member.email}`}
                          class="text-sm text-navy-600 hover:text-navy-800 block break-all"
                        >
                          {member.email}
                        </a>
                      )}
                      {member.url && (
                        <a
                          href={member.url.startsWith('http') ? member.url : `https://${member.url}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-sm text-navy-600 hover:text-navy-800 block break-all"
                        >
                          {member.url}
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              ))}
          </div>
        </div>

        <!-- Post-Docs -->
        <div class="mb-12">
          <h2 class="text-2xl font-serif text-navy-800 border-b border-gray-200 pb-2 mb-4 text-center">Post-Docs</h2>
          <div class="max-w-2xl mx-auto">
            <ul class="divide-y divide-gray-100">
              {postdocs.map((m) => (
                <li class="flex justify-between items-center py-2.5">
                  <span class="text-gray-800 font-medium">{m.name}</span>
                  <span class="text-sm text-gray-500">{m.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- PhD Scholars -->
        <div class="mb-12">
          <h2 class="text-2xl font-serif text-navy-800 border-b border-gray-200 pb-2 mb-4 text-center">PhD Scholars</h2>
          <div class="max-w-2xl mx-auto">
            <ul class="divide-y divide-gray-100">
              {phdStudents.map((m) => (
                <li class="flex justify-between items-center py-2.5">
                  <span class="text-gray-800 font-medium">{m.name}</span>
                  <span class="text-sm text-gray-500">{m.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Project Staff -->
        <div class="mb-12">
          <h2 class="text-2xl font-serif text-navy-800 border-b border-gray-200 pb-2 mb-4 text-center">Project Staff</h2>
          <div class="max-w-2xl mx-auto">
            <ul class="divide-y divide-gray-100">
              {projectStaff.map((m) => (
                <li class="flex justify-between items-center py-2.5">
                  <span class="text-gray-800 font-medium">{m.name}</span>
                  <span class="text-sm text-gray-500">{m.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Master Students 2nd Year -->
        <div class="mb-12">
          <h2 class="text-2xl font-serif text-navy-800 border-b border-gray-200 pb-2 mb-4 text-center">Master Students <span class="text-lg font-sans text-gray-500">(2nd Year)</span></h2>
          <div class="max-w-2xl mx-auto">
            <ul class="divide-y divide-gray-100">
              {masterStudents2ndYear.map((m) => (
                <li class="flex justify-between items-center py-2.5">
                  <span class="text-gray-800 font-medium">{m.name}</span>
                  <span class="text-sm text-gray-500">{m.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Master Students 1st Year -->
        <div class="mb-12">
          <h2 class="text-2xl font-serif text-navy-800 border-b border-gray-200 pb-2 mb-4 text-center">Master Students <span class="text-lg font-sans text-gray-500">(1st Year)</span></h2>
          <div class="max-w-2xl mx-auto">
            <ul class="divide-y divide-gray-100">
              {masterStudents1stYear.map((m) => (
                <li class="flex justify-between items-center py-2.5">
                  <span class="text-gray-800 font-medium">{m.name}</span>
                  <span class="text-sm text-gray-500">{m.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Administrative Staff -->
        <div class="mb-16">
          <h2 class="text-2xl font-serif text-navy-800 border-b border-gray-200 pb-2 mb-4 text-center">Administrative Staff</h2>
          <div class="max-w-2xl mx-auto">
            <ul class="divide-y divide-gray-100">
              {administrative.map((m) => (
                <li class="flex justify-between items-center py-2.5">
                  <span class="text-gray-800 font-medium">{m.name}</span>
                  <span class="text-sm text-gray-500">{m.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Join Us Section -->
        <div class="bg-navy-900 text-white p-8 rounded text-center">
          <h2 class="text-2xl font-semibold mb-4 font-serif">Join Our Team</h2>
          <p class="text-lg mb-6 text-gray-300">
            We are always looking for motivated individuals to join our research community
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
              <h3 class="font-semibold mb-2 font-serif">MS/PhD Students</h3>
              <p class="text-gray-400">Research opportunities available</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2 font-serif">Internships</h3>
              <p class="text-gray-400">Hands-on research experience</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2 font-serif">Project Staff</h3>
              <p class="text-gray-400">Full-time research positions</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>
