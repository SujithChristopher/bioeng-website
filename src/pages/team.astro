                      </a>
                    )}
                    {member.url && (
                      <a 
                        href={member.url.startsWith('http') ? member.url : `https://${member.url}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm text-blue-600 hover:text-blue-800 block break-all"
                      >
                        🔗 {member.url}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Join Us Section -->
        <div class="bg-blue-600 text-white p-8 rounded-lg text-center">
          <h2 class="text-2xl font-semibold mb-4">Join Our Team</h2>
          <p class="text-lg mb-6">
            We are always looking for motivated individuals to join our research community
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
              <h3 class="font-semibold mb-2">MS/PhD Students</h3>
              <p class="text-blue-100">Research opportunities available</p>
            </div>
            <div class="text-center">
              <h3 class="font-semibold mb-2">Internships</h3>
