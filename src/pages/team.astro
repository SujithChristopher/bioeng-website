function initials(name: string) {
  return name.replace(/^Dr\.\s*/, '').split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
}
---

<Layout title="Team - Department of Bioengineering, CMC Vellore">
  <div class="min-h-screen bg-white">
    <Header />

    <!-- Page Header -->
    <section class="py-12 bg-navy-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 font-serif">Our Team</h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Faculty, researchers, and students at the Department of Bioengineering, CMC Vellore
        </p>
      </div>
    </section>

    <section class="py-12 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Jump links -->
        <div class="flex flex-wrap gap-x-4 gap-y-1 mb-10 text-sm border-b border-gray-200 pb-4">
          <a href="#faculty" class="text-navy-600 hover:underline">Faculty ({faculty.length})</a>
          <span class="text-gray-300">·</span>
          <a href="#postdocs" class="text-navy-600 hover:underline">Post-Docs ({postdocs.length})</a>
          <span class="text-gray-300">·</span>
          <a href="#phd" class="text-navy-600 hover:underline">PhD Scholars ({phdStudents.length})</a>
          <span class="text-gray-300">·</span>
          <a href="#masters" class="text-navy-600 hover:underline">Master Students ({masterStudents1stYear.length + masterStudents2ndYear.length})</a>
          <span class="text-gray-300">·</span>
          <a href="#staff" class="text-navy-600 hover:underline">Project Staff ({projectStaff.length})</a>
          <span class="text-gray-300">·</span>
          <a href="#admin" class="text-navy-600 hover:underline">Administrative ({administrative.length})</a>
        </div>

        <!-- Faculty -->
        <div class="mb-10" id="faculty">
          <h2 class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-6">Faculty</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {faculty.map((member) => (
              <div class="border border-gray-200 rounded overflow-hidden">
                <div class="bg-gray-100 h-48 flex items-center justify-center overflow-hidden">
                  <img
                    src={member.image}
                    alt={member.name}
                    class="w-full h-full object-contain"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-bold text-navy-800 font-serif text-base leading-tight">{member.name}</h3>
                  <p class="text-xs text-gray-500 mt-0.5 mb-3">{member.title}</p>
                  {member.expertise.length > 0 && (
                    <div class="flex flex-wrap gap-1 mb-3">
                      {member.expertise.map((tag) => (
                        <span class="px-2 py-0.5 bg-navy-50 text-navy-700 text-xs rounded">{tag}</span>
                      ))}
                    </div>
                  )}
                  <div class="flex flex-wrap gap-x-3 gap-y-0.5">
                    {member.email && (
                      <a href={`mailto:${member.email}`} class="text-xs text-navy-600 hover:underline">Email</a>
                    )}
                    {member.url && (
                      <a href={member.url.startsWith('http') ? member.url : `https://${member.url}`} target="_blank" rel="noopener noreferrer" class="text-xs text-navy-600 hover:underline">Personal page</a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Post-Docs -->
        <div class="mb-10" id="postdocs">
          <h2 class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4">Post-Docs</h2>
          <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-3">
            {postdocs.map((m) => (
              <a href={m.url || undefined} target={m.url ? "_blank" : undefined} rel="noopener noreferrer" class={`text-center group ${!m.url ? 'pointer-events-none' : ''}`}>
                <div class="w-full aspect-square bg-navy-100 rounded overflow-hidden mb-1 flex items-center justify-center">
                  {m.image
                    ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" />
                    : <span class="text-navy-700 font-semibold text-sm">{initials(m.name)}</span>
                  }
                </div>
                <p class="text-xs text-gray-800 leading-tight group-hover:text-navy-600 line-clamp-2">{m.name}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- PhD Scholars -->
        <div class="mb-10" id="phd">
          <h2 class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4">PhD Scholars</h2>
          <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-3">
            {phdStudents.map((m) => (
              <a href={m.url || undefined} target={m.url ? "_blank" : undefined} rel="noopener noreferrer" class={`text-center group ${!m.url ? 'pointer-events-none' : ''}`}>
                <div class="w-full aspect-square bg-navy-100 rounded overflow-hidden mb-1 flex items-center justify-center">
                  {m.image
                    ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" />
                    : <span class="text-navy-700 font-semibold text-sm">{initials(m.name)}</span>
                  }
                </div>
                <p class="text-xs text-gray-800 leading-tight group-hover:text-navy-600 line-clamp-2">{m.name}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- Master Students -->
        <div class="mb-10" id="masters">
          <h2 class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4">Master Students</h2>
          <p class="text-xs text-gray-500 mb-3">2nd Year</p>
          <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-3 mb-6">
            {masterStudents2ndYear.map((m) => (
              <a href={m.url || undefined} target={m.url ? "_blank" : undefined} rel="noopener noreferrer" class={`text-center group ${!m.url ? 'pointer-events-none' : ''}`}>
                <div class="w-full aspect-square bg-navy-100 rounded overflow-hidden mb-1 flex items-center justify-center">
                  {m.image
                    ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" />
                    : <span class="text-navy-700 font-semibold text-sm">{initials(m.name)}</span>
                  }
                </div>
                <p class="text-xs text-gray-800 leading-tight group-hover:text-navy-600 line-clamp-2">{m.name}</p>
              </a>
            ))}
          </div>
          <p class="text-xs text-gray-500 mb-3">1st Year</p>
          <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-3">
            {masterStudents1stYear.map((m) => (
              <a href={m.url || undefined} target={m.url ? "_blank" : undefined} rel="noopener noreferrer" class={`text-center group ${!m.url ? 'pointer-events-none' : ''}`}>
                <div class="w-full aspect-square bg-navy-100 rounded overflow-hidden mb-1 flex items-center justify-center">
                  {m.image
                    ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" />
                    : <span class="text-navy-700 font-semibold text-sm">{initials(m.name)}</span>
                  }
                </div>
                <p class="text-xs text-gray-800 leading-tight group-hover:text-navy-600 line-clamp-2">{m.name}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- Project Staff -->
        <div class="mb-10" id="staff">
          <h2 class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4">Project Staff</h2>
          <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-3">
            {projectStaff.map((m) => (
              <a href={m.url || undefined} target={m.url ? "_blank" : undefined} rel="noopener noreferrer" class={`text-center group ${!m.url ? 'pointer-events-none' : ''}`}>
                <div class="w-full aspect-square bg-navy-100 rounded overflow-hidden mb-1 flex items-center justify-center">
                  {m.image
                    ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" />
                    : <span class="text-navy-700 font-semibold text-sm">{initials(m.name)}</span>
                  }
                </div>
                <p class="text-xs text-gray-800 leading-tight group-hover:text-navy-600 line-clamp-2">{m.name}</p>
                <p class="text-xs text-gray-400 leading-tight">{m.title}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- Administrative Staff -->
        <div class="mb-10" id="admin">
          <h2 class="text-xl font-bold text-navy-800 font-serif border-b border-gray-200 pb-2 mb-4">Administrative Staff</h2>
          <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-3">
            {administrative.map((m) => (
              <a href={m.url || undefined} target={m.url ? "_blank" : undefined} rel="noopener noreferrer" class={`text-center group ${!m.url ? 'pointer-events-none' : ''}`}>
                <div class="w-full aspect-square bg-navy-100 rounded overflow-hidden mb-1 flex items-center justify-center">
                  {m.image
                    ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" />
                    : <span class="text-navy-700 font-semibold text-sm">{initials(m.name)}</span>
                  }
                </div>
                <p class="text-xs text-gray-800 leading-tight group-hover:text-navy-600 line-clamp-2">{m.name}</p>
                <p class="text-xs text-gray-400 leading-tight">{m.title}</p>
              </a>
            ))}
          </div>
        </div>

      </div>
    </section>

    <Footer />
  </div>
</Layout>
